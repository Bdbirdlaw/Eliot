# =============================================================================
# Eliot OS environment
#
# The app runs fully on MOCK providers with NONE of the real secrets below.
# Copy this file to .env and leave the provider flags on "mock" for local dev.
# Going live is a provider swap: set a flag to "real" and fill the matching key.
#
# SECRETS NEVER REACH THE BROWSER. Everything here is read only in server code
# (route handlers, server actions, lib/server). Do not prefix any of these with
# NEXT_PUBLIC_.
# =============================================================================

# --- Database (Postgres) -----------------------------------------------------
# Any Postgres connection string. On Vercel this is injected by the Postgres /
# Neon integration. For local dev, point it at a local or hosted Postgres, for
# example: postgresql://postgres:postgres@localhost:5432/eliot
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eliot"

# --- Session signing (any long random string; required) ----------------------
# Generate one with: openssl rand -hex 32
AUTH_SECRET="dev-only-change-me-to-a-long-random-string"

# --- Development sign in shortcut --------------------------------------------
# When "true", the sign in page exposes one click sign in as each seeded user.
# MUST be "false" in any shared or production environment.
DEV_AUTH_SHORTCUT="true"

# Base URL used when printing magic links to the server console (mock email).
APP_URL="http://localhost:3000"

# Shared secret a scheduler (cron) presents to advance nurture journeys via
# POST /api/journeys/run. Leave empty in dev; the console button works without it.
CRON_SECRET=""

# --- Provider selection (mock | real) ----------------------------------------
MODEL_PROVIDER="mock"      # triage + drafting   (real => Anthropic)
EMAIL_PROVIDER="mock"      # outbound email      (real => Resend)
CALENDAR_PROVIDER="mock"   # availability + book (real => Google Calendar)
VAULT_SINK="mock"          # Handyman events     (real => synced vault path)
NOTIFY_PROVIDER="mock"     # escalation pings    (real => Resend / SMS)

# --- Anthropic (only when MODEL_PROVIDER=real) -------------------------------
ANTHROPIC_API_KEY=""
# Model string is fixed in code (claude-sonnet-4-6); do not override casually.

# --- Resend (only when EMAIL_PROVIDER=real or NOTIFY_PROVIDER=real) -----------
RESEND_API_KEY=""
EMAIL_FROM="Eliot OS <ops@example.com>"

# --- Google Calendar (only when CALENDAR_PROVIDER=real) ----------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""          # server side OAuth, offline access
GOOGLE_CALENDAR_ID="primary"     # the calendar that holds Eliot's busy time

# --- Vault handoff (only when VAULT_SINK=real) -------------------------------
# Absolute path to the dedicated inbox folder INSIDE the synced Obsidian vault.
# ProxyClaw's agent is the sole reader/reconciler of this folder. Confirm the
# event file contract with ProxyClaw before pointing this at the real vault.
VAULT_INBOX_PATH="/absolute/path/to/vault/_inbox/handyman"

# Where escalations are sent when NOTIFY_PROVIDER=real.
ELIOT_NOTIFY_EMAIL="eliot@example.com"

# --- Triage threshold (dollars). Auto approve at or under this when it can wait.
# Spec default is 500; consider starting at 200 and raising as trust grows.
TRIAGE_AUTO_APPROVE_THRESHOLD="500"
